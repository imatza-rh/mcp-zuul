# Required: Zuul base URL (no trailing slash, no /api suffix)
ZUUL_URL=https://softwarefactory-project.io/zuul

# Default tenant (optional, but recommended)
ZUUL_DEFAULT_TENANT=rdoproject.org

# Auth token for SSO-protected instances (optional)
# ZUUL_AUTH_TOKEN=

# HTTP timeout in seconds (default: 30)
# ZUUL_TIMEOUT=30

# === Required ===

# Zuul base URL (no trailing slash, no /api suffix)
ZUUL_URL=https://softwarefactory-project.io/zuul

# === Recommended ===

# Default tenant (saves passing tenant= on every tool call)
ZUUL_DEFAULT_TENANT=rdoproject.org

# === Authentication (pick one, not both) ===

# Bearer token for SSO-protected instances
# NEVER commit this file with a real token — use env vars
# ZUUL_AUTH_TOKEN=

# Kerberos/SPNEGO authentication (requires gssapi package)
# ZUUL_USE_KERBEROS=false

# === Server ===

# Transport: stdio (default), sse, or streamable-http
# MCP_TRANSPORT=stdio

# HTTP server bind address (non-stdio transports only)
# MCP_HOST=127.0.0.1

# HTTP server port (non-stdio transports only)
# MCP_PORT=8000

# === Behavior ===

# Read-only mode (default true) — set false to enable write tools
# ZUUL_READ_ONLY=true

# HTTP timeout in seconds
# ZUUL_TIMEOUT=30

# SSL certificate verification
# ZUUL_VERIFY_SSL=true

# === Tool Filtering (pick one, not both) ===

# Only enable these tools (comma-separated)
# ZUUL_ENABLED_TOOLS=list_builds,get_build,get_build_failures,get_build_log

# Disable these tools (comma-separated)
# ZUUL_DISABLED_TOOLS=enqueue,dequeue

# === Optional Integrations ===

# LogJuicer ML-based log anomaly detection
# LOGJUICER_URL=https://logjuicer.example.com
